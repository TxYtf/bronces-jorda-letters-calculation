rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to check if the user is an admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'Yavorskyy.Taras@gmail.com' || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // Rules for user profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Rules for text records history
    match /history/{recordId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // records should be immutable
    }

    // Rules for settings
    match /settings/{settingId} {
      allow read: if true; // anyone can view price settings
      allow write: if isAdmin();
    }

    // Helper to validate price presets
    function isValidPreset(data) {
      return data.keys().hasAll(['name', 'upper', 'lower', 'digits', 'digits3cm', 'digits4cm', 'punctuation', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.upper is number && data.upper >= 0 &&
             data.lower is number && data.lower >= 0 &&
             data.digits is number && data.digits >= 0 &&
             data.digits3cm is number && data.digits3cm >= 0 &&
             data.digits4cm is number && data.digits4cm >= 0 &&
             data.punctuation is number && data.punctuation >= 0 &&
             data.createdAt is string;
    }

    // Rules for price presets
    match /price_presets/{presetId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidPreset(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
